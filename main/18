#include <iostream>
using namespace std;

int main() {
    setlocale(LC_ALL, "Rus");
    int size;
    char texture;

    cout << "Размер: ";
    cin >> size;
    cout << "Текстура: ";
    cin >> texture;

    system("cls");
    cout << endl << "Результат:" << endl << endl;

    for (int y = 0; y < size; y++) {
        for (int x = 0; x < size; x++) {
            if (y == size / 2 || x == size / 2) {
                cout << texture << " ";
            }
            else {
                cout << ". ";
            }
        }
        cout << endl;
    }
    return 0;
}
