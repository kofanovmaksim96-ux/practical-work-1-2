#include <iostream>
using namespace std;

int main() {
	setlocale(LC_ALL, "Russian");
	int a;
	cout << "Кол-во символов:";
	cin >> a;

	for (int b = 0;b < a; b++) {
		if (b % 2 == 0)
			cout << "*";
		else
			cout << " ";
	}
	cout << endl;
	for (int b = 0;b < a; b++) {
		if (b % 2 != 0)
			cout << "*";
		else
			cout << " ";
	}
	return 0;

}
