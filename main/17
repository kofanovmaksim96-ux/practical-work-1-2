#include <iostream>
using namespace std;

int main() {
    setlocale(LC_ALL, "Rus");
    int size;
    char texture;

    cout << "Размер: ";
    cin >> size;
    cout << "Текстура: ";
    cin >> texture;

    cout << endl << "Результат:" << endl << endl;

    for (int i = 0; i < size; i++) {
        for (int j = 0; j < size; j++) {
           
            if (i == j || i + j == size - 1) {
                cout << texture << " ";
            }
            else {
                cout << ". ";
            }
        }
        cout << endl;
    }

    return 0;
}
